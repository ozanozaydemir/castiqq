      "sectionLabel": "Features",
      "title": "Everything in one place",
      "subtitle": "Say goodbye to scattered spreadsheets, endless emails, and WhatsApp groups.",
      "items": {
        "projectManagement": {
          "title": "Project & Role Management",
          "desc": "Create projects for every production, define roles for every project. Full control with status, deadlines, and attributes."
        },
        "talentDb": {
          "title": "Talent Database",
          "desc": "Record complete profiles with photos, languages, experience, and physical attributes. Filter in seconds."
        },
        "multiVideo": {
          "title": "Multi-Video Review",
          "desc": "Up to 3 videos per candidate. Switch between tabs to compare all performances side by side."
        },
        "starRating": {
          "title": "5-Star Rating",
          "desc": "Rate every candidate, sort by score. Instantly surface the best in meetings."
        },
        "tags": {
          "title": "Tag System",
          "desc": "\"Strong performance\", \"Camera-friendly\", \"Open to direction\" — define custom org-level tags."
        },
        "collections": {
          "title": "Custom Collections",
          "desc": "Save your favorite talent in custom lists. Build shortlists independent of projects, share them."
        },
        "timestampNotes": {
          "title": "Timestamp Notes",
          "desc": "Leave a note at the exact moment in the video. Click it and the video jumps to that point. Instant, precise feedback."
        },
        "whatsapp": {
          "title": "WhatsApp Integration",
          "desc": "Send new audition requests with a ready-made message template via WhatsApp in one click."
        },
        "dnd": {
          "title": "Drag & Drop Sorting",
          "desc": "Reorder candidate priorities by dragging. Dynamically re-rank during meetings."
        },
        "teamAccess": {
          "title": "Team & Access Management",
          "desc": "Control access with Admin, Member, and Viewer roles. Give external stakeholders a secure link."
        },
        "dashboard": {
          "title": "Dashboard & Analytics",
          "desc": "Active projects, pending auditions, upcoming deadlines — your entire operation on one screen, live."
        },
        "security": {
          "title": "Multi-tenant Security",
          "desc": "Every agency and production company works in complete isolation. Your data belongs only to you."
        }
      }
